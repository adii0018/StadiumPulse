# =============================================================================
# StadiumPulse — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Groq API
# Get your key at https://console.groq.com
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk-...

# ---------------------------------------------------------------------------
# JWT Authentication (Ops Command Center)
# Use a strong random secret in production: openssl rand -base64 64
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=8h

# ---------------------------------------------------------------------------
# Demo Credentials (visible in the UI for judges — change for production)
# ---------------------------------------------------------------------------
DEMO_ADMIN_EMAIL=admin@stadiumpulse.com
DEMO_ADMIN_PASSWORD=demo1234

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Rate Limiting
# PUBLIC: token bucket — requests per window for unauthenticated fans
# STAFF: higher limit for authenticated ops users
# ---------------------------------------------------------------------------
RATE_LIMIT_PUBLIC_MAX=10
RATE_LIMIT_PUBLIC_WINDOW_MS=10000
RATE_LIMIT_STAFF_MAX=50
RATE_LIMIT_STAFF_WINDOW_MS=10000

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------
LRU_CACHE_MAX_SIZE=500
LRU_CACHE_TTL_MS=300000

# ---------------------------------------------------------------------------
# Crowd Simulator
# ---------------------------------------------------------------------------
CROWD_UPDATE_INTERVAL_MS=1000

# ---------------------------------------------------------------------------
# Production Upgrade Paths (not used in dev — documented here for reference)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/stadiumpulse
# REDIS_URL=redis://localhost:6379
# CHROMA_URL=http://localhost:8000
